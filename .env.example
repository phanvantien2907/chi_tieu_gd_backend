# -----------------------------------------------------------------------------
# APP
# -----------------------------------------------------------------------------
# HTTP port for the NestJS server (default used if unset: 3000)
PORT=3000

# Public base URL of this API (used for wallet invite links; no trailing slash)
SYSTEM_URL=https://example.com

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# PostgreSQL connection string (Drizzle ORM)
DATABASE_URL=postgresql://postgres:your_database_password_here@localhost:5432/chi_tieu_gd_dev

# -----------------------------------------------------------------------------
# AUTH
# -----------------------------------------------------------------------------
# Secret for signing and verifying JWT access tokens (use a long random string in production)
JWT_SECRET=your_jwt_secret_here
